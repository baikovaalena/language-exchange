{
  "extends": [
    "stylelint-config-standard-scss",
    "stylelint-config-prettier-scss"
  ],
  "plugins": ["stylelint-order"],
  "rules": {
    "order/properties-order": [
      "content",
      "display",
      "visibility",
      "position",
      "top",
      "right",
      "bottom",
      "left",
      "z-index",
      "flex",
      "flex-direction",
      "flex-wrap",
      "flex-flow",
      "justify-content",
      "align-items",
      "align-content",
      "gap",
      "grid",
      "grid-template",
      "grid-template-columns",
      "grid-template-rows",
      "grid-area",
      "width",
      "min-width",
      "max-width",
      "height",
      "min-height",
      "max-height",
      "margin",
      "margin-top",
      "margin-right",
      "margin-bottom",
      "margin-left",
      "padding",
      "padding-top",
      "padding-right",
      "padding-bottom",
      "padding-left",
      "overflow",
      "overflow-x",
      "overflow-y",
      "border",
      "border-radius",
      "background",
      "background-color",
      "color",
      "font",
      "font-family",
      "font-size",
      "font-weight",
      "font-style",
      "line-height",
      "letter-spacing",
      "text-align",
      "text-decoration",
      "text-transform",
      "white-space",
      "cursor",
      "opacity",
      "transition",
      "transform",
      "animation"
    ],
    "scss/at-rule-no-unknown": true,
    "selector-class-pattern": null
  }
}
